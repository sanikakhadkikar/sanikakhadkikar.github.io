{{/* Red Hover Theme Across Website */}}
<style>
/* sanika R Beattie header brand - red underline */
.navbar-brand::after {
  background: #ff0000 !important;
  background-image: none !important;
}

.navbar-brand:hover {
  color: #ff0000 !important;
}
/* Header Navigation Links - Red hover underline */
header .nav-link:hover,
header .navbar-nav .nav-link:hover,
.navbar .nav-link:hover,
.navbar .navbar-nav .nav-link:hover,
nav .nav-link:hover {
  color: #ff0000 !important;
  border-bottom-color: #ff0000 !important;
}

/* Remove active link underline */
header .nav-link.active,
.navbar .nav-link.active,
nav .nav-link.active {
  border-bottom: none !important;
}

/* Hugo Blox navigation - remove underline animations */
.navbar-nav .nav-link {
  position: relative;
  border-bottom: none !important;
}

.navbar-nav .nav-link:after,
.navbar-nav .nav-link::after {
  display: none !important; /* Remove underline animations */
}

.navbar-nav .nav-link:hover:after,
.navbar-nav .nav-link:hover::after {
  display: none !important; /* Remove underline animations */
}

/* Remove any gradient backgrounds */
.navbar-nav .nav-link:before,
.navbar-nav .nav-link::before {
  display: none !important;
}

/* Menu item hover states */
.dropdown-item:hover,
.dropdown-item:focus {
  background-color: rgba(255, 0, 0, 0.1) !important;
  color: #ff0000 !important;
}

/* All website links - smooth color transition */
a {
  transition: color 0.3s ease;
}

a:hover {
  color: #ff0000 !important;
}

/* Button hover states */
.btn:hover,
button:hover {
  border-color: #ff0000 !important;
  color: #ff0000 !important;
}

.btn-primary:hover {
  background-color: #ff0000 !important;
  border-color: #ff0000 !important;
  color: #ffffff !important;
}

/* News carousel buttons */
.nav-btn:hover {
  background: #ff0000 !important;
  color: #ffffff !important;
}

/* Tags and categories hover */
.tag:hover,
.badge:hover,
.category:hover {
  background-color: #ff0000 !important;
  color: #ffffff !important;
}

/* Featured Science sections - remove green effects */
.featured-content a:hover,
.highlight a:hover,
.article-grid a:hover,
.featured a:hover {
  color: #ff0000 !important;
  text-decoration: none !important;
  box-shadow: none !important;
  text-shadow: none !important;
}

/* Remove any green underlines/shadows from featured items */
.article-grid .article-title a,
.featured .article-title a,
.article-title a,
#featured a,
.featured-content a,
section#featured a,
.article-grid a,
.article-style a {
  box-shadow: none !important;
  text-shadow: none !important;
  background-image: none !important;
  text-decoration: none !important;
  border-bottom: none !important;
}

/* Remove underlines on hover for all featured section links */
#featured a:hover,
.featured-content a:hover,
section#featured a:hover,
.article-grid a:hover,
.article-style a:hover,
.article-grid .article-title a:hover,
.featured .article-title a:hover {
  box-shadow: none !important;
  text-shadow: none !important;
  background-image: none !important;
  text-decoration: none !important;
  border-bottom: none !important;
}

/* Featured science titles - make them red instead of green */
.article-grid .article-title,
.featured .article-title,
h3.article-title,
#featured .article-title,
.featured-content .article-title,
section#featured .article-title {
  color: #ff0000 !important;
}

.article-grid .article-title a,
.featured .article-title a,
#featured .article-title a,
.featured-content .article-title a,
section#featured .article-title a {
  color: #ff0000 !important;
}

/* Student Projects and Notes titles - red instead of green */
.projects .article-title,
.notes .article-title,
#projects .article-title,
#notes .article-title,
.project-title,
.note-title,
.portfolio-item .article-title,
.compact .article-title {
  color: #ff0000 !important;
}

.projects .article-title a,
.notes .article-title a,
#projects .article-title a,
#notes .article-title a,
.project-title a,
.note-title a,
.portfolio-item .article-title a,
.compact .article-title a {
  color: #ff0000 !important;
}

/* Pagination */
.page-link:hover {
  background-color: #ff0000 !important;
  border-color: #ff0000 !important;
  color: #ffffff !important;
}

/* Social media icons */
.share-icon:hover,
.social-icon:hover {
  color: #ff0000 !important;
}

/* Footer links */
footer a:hover {
  color: #ff0000 !important;
}

/* Table of contents */
.toc a:hover {
  color: #ff0000 !important;
}

/* Code copy button */
.copy-code-button:hover {
  background-color: #ff0000 !important;
  color: #ffffff !important;
}

/* Search results */
.search-hit a:hover {
  color: #ff0000 !important;
}

/* Publication links */
.publication-links a:hover {
  color: #ff0000 !important;
}

/* Publication buttons - PDF, CITE, DOI, CUSTOM LINK */
.btn-outline-primary,
.publication-links .btn-outline-primary,
.btn-links .btn,
.btn-links .btn-outline-primary {
  color: #ff0000 !important;
  border-color: #ff0000 !important;
}

.btn-outline-primary:hover,
.publication-links .btn-outline-primary:hover,
.btn-links .btn:hover,
.btn-links .btn-outline-primary:hover {
  background-color: #ff0000 !important;
  border-color: #ff0000 !important;
  color: #ffffff !important;
}

/* Featured publication cards */
.card:hover {
  border-color: #ff0000 !important;
}

.card-title a:hover {
  color: #ff0000 !important;
}

/* Collaborator links hover - remove green background */
.collaborator-item:hover {
  background: none !important;
  background-color: transparent !important;
}

.collaborator-item a:hover {
  color: #ff0000 !important;
  background: none !important;
  background-color: transparent !important;
}

/* Ensure no green background on collaborator items */
.collaborators-grid .collaborator-item {
  background: none !important;
  transition: none !important;
}

.collaborators-grid .collaborator-item:hover {
  background: none !important;
  background-color: transparent !important;
  box-shadow: none !important;
}

/* Override any blue hover states */
a:hover,
.text-primary:hover,
.link-primary:hover {
  color: #ff0000 !important;
}

/* Hugo Blox specific overrides */
.hb-navbar-nav .nav-link:hover,
.hb-navbar-nav .nav-link:focus {
  color: #ff0000 !important;
}

/* Ensure header underlines are completely removed */
.navbar-light .navbar-nav .nav-link:hover::after,
.navbar-dark .navbar-nav .nav-link:hover::after {
  display: none !important;
}

/* Additional specificity for Hugo Blox themes */
.hb-navbar .navbar-nav .nav-link::after,
header .navbar .navbar-nav .nav-link::after {
  display: none !important;
}

/* Remove default underlines and borders */
.navbar-nav .nav-link {
  text-decoration: none !important;
  border: none !important;
  border-bottom: none !important;
}
</style>